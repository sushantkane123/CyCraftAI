# ── BradlyAI Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Application ──
APP_NAME="BradlyAI - Driverless SOC & Automated Incident Response"
APP_VERSION="2.4.0"
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# ── Database ──
# Default: SQLite (great for dev / single-node demo)
DATABASE_URL=sqlite+aiosqlite:///./bradlyai_soc.db
# Production: Postgres
# DATABASE_URL=postgresql+asyncpg://bradlyai:secret@postgres:5432/bradlyai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── CORS ──
CORS_ALLOWED_ORIGINS=["*"]

# ── AI / LLM Configuration ──
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk-your_key_here
DEFAULT_AI_MODEL=gpt-4-turbo-preview
# LOCAL_LLM_MODEL_PATH=/models/llama-3.1-8b-instruct-q4_k_m.gguf

# ── Autonomous SOC Settings ──
AUTO_CONTAINMENT_THRESHOLD=0.85
LIVE_SIMULATION_WORKER_ACTIVE=true
SIMULATION_INTERVAL_SECONDS=30

# ── Rate Limiting ──
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

# ── Wazuh Manager API ──
WAZUH_ENABLED=false
WAZUH_DRY_RUN=true
WAZUH_CLOSE_MODE=comment_only
WAZUH_MANAGER_URL=
WAZUH_USER=
WAZUH_PASSWORD=
WAZUH_VERIFY_SSL=true

# ══════════════════════════════════════════════════════════════════════
# ── Authentication / RBAC / SSO (NEW) ───────────────────────────────
# ══════════════════════════════════════════════════════════════════════
AUTH_ENABLED=true
# CRITICAL: change AUTH_JWT_SECRET in production to a random 64+ char string
AUTH_JWT_SECRET=CHANGE-ME-IN-PROD-please-use-a-random-secret-min-64-chars-long
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_REQUIRE_MFA_FOR_ADMINS=true
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

# OIDC SSO (Okta, Azure AD, Google, Auth0, Keycloak)
SSO_OIDC_ENABLED=false
SSO_OIDC_ISSUER=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/oidc/callback
SSO_OIDC_SCOPES=openid email profile groups

# SAML SSO
SSO_SAML_ENABLED=false
SSO_SAML_ENTITY_ID=bradlyai
SSO_SAML_IDP_METADATA_URL=
SSO_SAML_SP_CERT_PATH=
SSO_SAML_SP_KEY_PATH=

RBAC_DEFAULT_ROLE=analyst_l1
RBAC_ADMIN_ROLE=admin

# ══════════════════════════════════════════════════════════════════════
# ── Multi-Tenancy ───────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
MULTI_TENANCY_ENABLED=false
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Default Tenant

# ══════════════════════════════════════════════════════════════════════
# ── Notifications — Slack / Teams / PagerDuty / Email / Webhook ──────
# ══════════════════════════════════════════════════════════════════════
NOTIFICATIONS_ENABLED=false

# Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#soc-alerts
SLACK_L2_CHANNEL=#soc-l2

# Microsoft Teams
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# PagerDuty
PAGERDUTY_ENABLED=false
PAGERDUTY_INTEGRATION_KEY=
PAGERDUTY_DEFAULT_SERVICE_KEY=

# Email (SMTP)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=soc@bradlyai.local
EMAIL_L2_DISTRIBUTION_LIST=

# Generic webhook
WEBHOOK_NOTIFY_ENABLED=false
WEBHOOK_NOTIFY_URL=

# ══════════════════════════════════════════════════════════════════════
# ── EDR Integrations ────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
EDR_ENABLED=false
EDR_DRY_RUN=true
EDR_PROVIDER=none                 # none | crowdstrike | defender | sentinelone | carbonblack

CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

SENTINELONE_API_TOKEN=
SENTINELONE_BASE_URL=

CARBONBLACK_API_ID=
CARBONBLACK_API_SECRET=
CARBONBLACK_BASE_URL=

# ══════════════════════════════════════════════════════════════════════
# ── Network Containment ─────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
NETWORK_ENABLED=false
NETWORK_DRY_RUN=true
NETWORK_PROVIDER=none             # none | paloalto | fortinet | cisco_asa | checkpoint

PALOALTO_BASE_URL=
PALOALTO_API_KEY=
PALOALTO_VSYS=vsys1

FORTINET_BASE_URL=
FORTINET_API_TOKEN=

CISCO_ASA_BASE_URL=
CISCO_ASA_USERNAME=
CISCO_ASA_PASSWORD=

CHECKPOINT_BASE_URL=
CHECKPOINT_USERNAME=
CHECKPOINT_PASSWORD=

# ══════════════════════════════════════════════════════════════════════
# ── Identity Containment ────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
IDENTITY_ENABLED=false
IDENTITY_DRY_RUN=true
IDENTITY_PROVIDER=none             # none | azure_ad | okta

AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

OKTA_DOMAIN=
OKTA_API_TOKEN=

# ══════════════════════════════════════════════════════════════════════
# ── ITSM ─────────────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
ITSM_ENABLED=false
ITSM_PROVIDER=none                 # none | servicenow | jira | zendesk

SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_DEFAULT_ASSIGNMENT_GROUP=SOC L2
SERVICENOW_IMPACT=2
SERVICENOW_URGENCY=2

JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=SEC

ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# ══════════════════════════════════════════════════════════════════════
# ── Additional SIEMs ────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
SIEM_SPLUNK_ENABLED=false
SIEM_SPLUNK_HOST=
SIEM_SPLUNK_PORT=8089
SIEM_SPLUNK_TOKEN=

SIEM_ELASTIC_ENABLED=false
SIEM_ELASTIC_URL=
SIEM_ELASTIC_USERNAME=
SIEM_ELASTIC_PASSWORD=
SIEM_ELASTIC_API_KEY=

SIEM_QRADAR_ENABLED=false
SIEM_QRADAR_HOST=
SIEM_QRADAR_TOKEN=

SIEM_SENTINEL_ENABLED=false
SIEM_SENTINEL_TENANT_ID=
SIEM_SENTINEL_CLIENT_ID=
SIEM_SENTINEL_CLIENT_SECRET=
SIEM_SENTINEL_SUBSCRIPTION_ID=
SIEM_SENTINEL_RESOURCE_GROUP=
SIEM_SENTINEL_WORKSPACE_NAME=

# ══════════════════════════════════════════════════════════════════════
# ── Threat Intel ─────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
THREATINTEL_ENABLED=false
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
MISP_URL=
MISP_API_KEY=

# ══════════════════════════════════════════════════════════════════════
# ── Playbook Engine ──────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
PLAYBOOKS_ENABLED=true
PLAYBOOKS_DIR=./playbooks
PLAYBOOKS_DEFAULT_TIMEOUT_SECONDS=600
PLAYBOOKS_MAX_STEPS=50
PLAYBOOKS_REQUIRE_APPROVAL_FOR=isolate_host,disable_user,delete_data

# ══════════════════════════════════════════════════════════════════════
# ── Sigma Rule Engine ────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
SIGMA_ENABLED=true
SIGMA_RULES_DIR=./sigma_rules
SIGMA_AUTO_UPDATE=false
SIGMA_REPO_URL=https://github.com/SigmaHQ/sigma.git

# ══════════════════════════════════════════════════════════════════════
# ── Compliance Reporting ─────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
COMPLIANCE_FRAMEWORKS=nist_800_61,soc2,iso_27001
COMPLIANCE_REPORT_DIR=./reports

# ══════════════════════════════════════════════════════════════════════
# ── Observability ────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════
METRICS_ENABLED=true
METRICS_PATH=/metrics
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bradlyai
