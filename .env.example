# ── BradlyAI Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Application
APP_NAME="BradlyAI - Driverless SOC & Automated Incident Response"
APP_VERSION="2.1.0-PRO"
ENVIRONMENT=development

# Database (SQLite is the default — no config needed)
DATABASE_URL=sqlite+aiosqlite:///./bradlyai_soc.db

# ── AI / LLM Configuration ────────────────────────────────────────────
# Choose your provider: 'groq' (Llama-3, free tier) or 'openai' (GPT-4)
LLM_PROVIDER=groq

# Groq API Key (get one free at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# OpenAI API Key (get one at https://platform.openai.com)
OPENAI_API_KEY=sk-your_key_here

# Default model for OpenAI
DEFAULT_AI_MODEL=gpt-4-turbo-preview

# ── Autonomous SOC Settings ────────────────────────────────────────────
# AI confidence threshold (0.0–1.0) for auto-containment
AUTO_CONTAINMENT_THRESHOLD=0.85

# Enable background live simulation worker
LIVE_SIMULATION_WORKER_ACTIVE=true

# How often the simulation generates new alerts (seconds)
SIMULATION_INTERVAL_SECONDS=30

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60
